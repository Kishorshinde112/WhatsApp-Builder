# ===========================================
# WhatsApp Campaign Builder - Environment Config
# ===========================================

# PostgreSQL Database
DATABASE_URL=postgresql://whatsapp:whatsapp_secret@localhost:5432/whatsapp_campaigns
POSTGRES_USER=whatsapp
POSTGRES_PASSWORD=whatsapp_secret
POSTGRES_DB=whatsapp_campaigns

# Server Configuration
PORT=8080
NODE_ENV=development
BASE_PATH=/

# Mock Provider Settings
MOCK_PROVIDER_DELAY_MS=500
MOCK_PROVIDER_FAIL_RATE=0.05

# ===========================================
# WhatsApp Provider Configurations
# ===========================================

# Green API (https://green-api.com)
# Get credentials from: https://console.green-api.com
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# Evolution API (https://evolution-api.com)
# Self-hosted instance or cloud service
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=

# ===========================================
# Webhook Configuration (for production)
# ===========================================
# Set this to your public URL where providers can send webhooks
# Example: https://yourdomain.com/api/webhooks
WEBHOOK_BASE_URL=
